{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "tei-ui",
  "homepage": "https://github.com/DimensionTEI/tei-ui",
  "items": [
    {
      "name": "tokens",
      "type": "registry:style",
      "description": "Tokens TEI (CSS vars, paleta clara/oscura, fuentes Nunito + JetBrains Mono). Instala primero — todos los componentes dependen."
    },
    {
      "name": "utils",
      "type": "registry:lib",
      "description": "Helper cn() para componer clases (clsx + tailwind-merge)",
      "dependencies": [
        "clsx",
        "tailwind-merge"
      ]
    },
    {
      "name": "avatar",
      "type": "registry:ui",
      "description": "Primitivo TEI: avatar",
      "dependencies": [
        "@radix-ui/react-avatar"
      ],
      "registryDependencies": [
        "utils"
      ]
    },
    {
      "name": "badge",
      "type": "registry:ui",
      "description": "Primitivo TEI: badge",
      "dependencies": [
        "class-variance-authority"
      ],
      "registryDependencies": [
        "utils"
      ]
    },
    {
      "name": "button",
      "type": "registry:ui",
      "description": "Primitivo TEI: button",
      "dependencies": [
        "@radix-ui/react-slot",
